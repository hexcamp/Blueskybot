# Bluesky Credentials
BLUESKY_USERNAME=your_username@provider.com
BLUESKY_PASSWORD=your_secure_password

# Address to post to, change if using alternative PDS
SERVICE_URL=https://bsky.social

# Alt-text image descriptions (optional)
# Requires a Gemini API key — get one free at https://aistudio.google.com/apikey
ALT_TEXT_ENABLED=false
ALT_TEXT_LANGUAGE=sv
GEMINI_API_KEY=your_gemini_api_key

# Alt-text provider: gemini (default) or openai
ALT_TEXT_PROVIDER=gemini
OPENAI_API_KEY=your_openai_api_key
